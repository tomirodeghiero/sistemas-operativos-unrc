#!/bin/sh
# pre-push hook — bloquea force pushes de forma estricta.
#
# Capas de defensa:
#   1) Inspecciona el comando original (parent process). Si aparecen
#      --force, -f, --force-with-lease, --force-if-includes, o un refspec
#      con prefijo '+', se rechaza el push inmediatamente.
#   2) Inspecciona el efecto sobre las refs. Bloquea:
#         - non-fast-forward (reescritura de historia en ramas)
#         - sobreescritura de tags existentes
#         - borrado de ramas o tags remotos
#
# Sin bypass por env var. Limitación inherente de git: 'git push --no-verify'
# saltea cualquier hook. La defensa real para el equipo es la branch
# protection del server (GitHub Rulesets / Branch Protection).

zero="0000000000000000000000000000000000000000"
blocked=0

# ---------- Capa 1: flags en la línea de comando original ----------
parent_cmd=""
if [ -r "/proc/$PPID/cmdline" ]; then
  # Linux: cmdline es null-separated
  parent_cmd=$(tr '\0' ' ' < "/proc/$PPID/cmdline")
else
  # macOS / BSD
  parent_cmd=$(ps -ww -o command= -p "$PPID" 2>/dev/null || true)
fi

for tok in $parent_cmd; do
  case "$tok" in
    --force|-f|--force-with-lease|--force-with-lease=*|--force-if-includes)
      echo ""
      echo "🚫 Force push bloqueado"
      echo "Detectado el flag '$tok' en el comando."
      echo "No está permitido usar --force / -f / --force-with-lease en este repo."
      echo ""
      blocked=1
      ;;
    +refs/*|+*:*)
      echo ""
      echo "🚫 Force push bloqueado"
      echo "Detectado refspec con prefijo '+' (force): '$tok'."
      echo "No está permitido forzar refs en este repo."
      echo ""
      blocked=1
      ;;
  esac
done

# ---------- Capa 2: efecto sobre las refs ----------
while read local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/*|refs/tags/*) ;;
    *) continue ;;
  esac

  ref_name=$(echo "$remote_ref" | sed 's#refs/heads/##; s#refs/tags/##')

  # Crear rama/tag nuevo: permitido
  if [ "$remote_sha" = "$zero" ]; then
    continue
  fi

  # Borrar rama/tag remoto: bloqueado
  if [ "$local_sha" = "$zero" ]; then
    echo ""
    echo "🚫 Push bloqueado"
    echo "No está permitido eliminar la referencia remota: $ref_name"
    echo ""
    blocked=1
    continue
  fi

  # Sobreescribir tag existente: bloqueado
  case "$remote_ref" in
    refs/tags/*)
      if [ "$local_sha" != "$remote_sha" ]; then
        echo ""
        echo "🚫 Force push bloqueado"
        echo "No está permitido sobrescribir el tag remoto: $ref_name"
        echo ""
        blocked=1
      fi
      continue
      ;;
  esac

  # Rama: bloquear non-fast-forward (reescritura de historia)
  if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
    echo ""
    echo "🚫 Force push bloqueado"
    echo "No está permitido reescribir historia en: $ref_name"
    echo ""
    echo "   Local : $local_sha"
    echo "   Remote: $remote_sha (tiene commits que tu rama local no tiene)"
    echo ""
    echo "Hacé:  git fetch && git pull --rebase"
    echo ""
    blocked=1
  fi
done

if [ "$blocked" -eq 1 ]; then
  echo "Si reescribir historia es realmente necesario, coordinarlo con el equipo."
  echo "Recordatorio: la protección real corre del lado del server (GitHub branch protection)."
  echo ""
fi

exit $blocked
